{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/architecture-flows.schema.json",
  "title": "Architecture Flows",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "metadata", "evidence", "nodes", "edges", "flows"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repository", "branch", "commit", "generatedAt", "generationMode", "privacy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "generationMode": {
          "type": "string",
          "enum": ["codex-session", "api-structured-output", "manual"]
        },
        "incrementalMode": {
          "description": "Regeneration strategy used for this artifact. Optional for legacy artifacts; incremental tooling reports diagnostics when missing.",
          "type": "string",
          "enum": ["full", "delta", "verify-only"]
        },
        "schemaVersion": {
          "description": "Schema version used by the generator or planner metadata.",
          "type": "string"
        },
        "sourceCommit": {
          "description": "Source repository commit used for evidence and committed-change detection.",
          "type": "string"
        },
        "artifactHash": {
          "description": "Canonical artifact hash computed by incremental planning.",
          "type": "string"
        },
        "parentArtifactHash": {
          "description": "Previous artifact hash when regenerating from an earlier artifact; null for a root artifact.",
          "type": ["string", "null"]
        },
        "extractorVersions": {
          "description": "Deterministic local extractor and verifier versions or hashes.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "privacy": {
          "type": "string",
          "enum": ["local-only", "redacted-evidence-approved", "publish-approved"]
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/flow" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" },
      "default": []
    }
  },
  "$defs": {
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall"],
      "properties": {
        "overall": { "$ref": "#/$defs/confidenceValue" },
        "existence": { "$ref": "#/$defs/confidenceValue" },
        "direction": { "$ref": "#/$defs/confidenceValue" },
        "semantics": { "$ref": "#/$defs/confidenceValue" },
        "completeness": { "$ref": "#/$defs/confidenceValue" }
      }
    },
    "confidenceValue": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "severity", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind", "from", "to", "evidence", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "uncertaintyReason": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind", "path", "provenance", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string" },
        "language": { "type": "string" },
        "provenance": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "contentHash": { "type": "string" },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "startLine": { "type": "integer", "minimum": 1 },
            "endLine": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "summary", "trigger", "steps"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "trigger": { "type": "string", "minLength": 1 },
        "entry": { "type": "string" },
        "exit": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/flowStep" }
        }
      }
    },
    "flowStep": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "order", "node", "description", "evidence", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 1 },
        "node": { "type": "string", "minLength": 1 },
        "edge": { "type": "string" },
        "description": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "uncertaintyReason": { "type": "string" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind", "label", "evidence", "confidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "symbol": { "type": "string" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "uncertaintyReason": { "type": "string" }
      }
    }
  }
}
